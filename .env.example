# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values. Never commit .env.
# ---------------------------------------------------------------------------

# --- Budget ---
MONTHLY_BUDGET=10000
CURRENCY=INR

# --- Email (active alert channel) ---
# Using Gmail: turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste the 16-char value below
# (remove spaces). SMTP_USER is your full Gmail address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# Optional: default to SMTP_USER if left blank.
EMAIL_FROM=
EMAIL_TO=you@gmail.com

# --- Telegram (inactive; restore when the ban lifts) ---
# 1. Message @BotFather on Telegram -> /newbot -> copy the token here.
# 2. Send any message to your new bot, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy your chat id.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# --- Local server ---
# Secret the iOS Shortcut must send so randoms can't POST fake transactions.
WEBHOOK_SECRET=change-me-to-a-long-random-string
PORT=5000

# --- Kotak Balance Enquiry API ---
# UAT values come straight from the balance tech doc. Production URL is the
# one Kotak fills in for you after approval.
KOTAK_BASE_URL=https://apigwuat.kotak.com:8443
KOTAK_BALANCE_PATH=/dap_balance_enquiry
KOTAK_API_ID=b330f15c54042c5fc9e02ce58d50b68d
KOTAK_ACCOUNT_NUMBER=0111110000123

# --- Kotak OAuth (client_credentials grant) ---
# Per the OAuth doc: POST form-urlencoded to the token URL with client_id +
# client_secret in the body. The client_id is the "CLIENT ID" from the balance
# doc; the client_secret is NOT in either PDF -> get it from the developer
# portal (your approved application's credentials).
KOTAK_TOKEN_URL=https://apigwuat.kotak.com:8443/auth/oauth/v2/token
KOTAK_CLIENT_ID=l7xxdb09661032a64a5a8cfbbcdd86ecef9d
KOTAK_CLIENT_SECRET=your-client-secret-from-portal

# Set to "1" to skip the real API and use a fake EFFAVL value (for local
# testing before your credentials are live).
MOCK_KOTAK=0
MOCK_EFFAVL=42000.00
